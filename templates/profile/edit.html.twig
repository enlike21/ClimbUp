{% extends 'base.html.twig' %}

{% block title %}Tu Perfil - EscaladaApp{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .profile-container {
            max-width: 500px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .profile-title {
            font-size: 2.5rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 2rem;
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            position: relative;
        }

        .profile-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            border-radius: 2px;
        }

        .profile-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            padding: 2rem;
            transition: all 0.3s ease;
        }

        .profile-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
        }

        .form-group {
            margin-bottom: 1.5rem;
            position: relative;
        }

        .form-label {
            color: rgba(255, 255, 255, 0.9);
            font-weight: 500;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-control {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            padding: 0.8rem 1rem 0.8rem 2.5rem;
            color: white;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            background: rgba(255, 255, 255, 0.15);
            border-color: rgba(52, 152, 219, 0.5);
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25);
            color: white;
        }

        .input-icon {
            position: absolute;
            left: 1rem;
            top: 2.7rem;
            color: rgba(255, 255, 255, 0.5);
            transition: all 0.3s ease;
        }

        .form-control:focus + .input-icon {
            color: #3498DB;
        }

        .btn-profile {
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            border: none;
            border-radius: 12px;
            padding: 1rem;
            font-weight: 600;
            color: white;
            width: 100%;
            transition: all 0.3s ease;
            margin-top: 1rem;
        }

        .btn-profile:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(52, 152, 219, 0.4);
        }

        @media (max-width: 768px) {
            .profile-container {
                padding: 1rem;
            }

            .profile-title {
                font-size: 2rem;
            }

            .profile-card {
                padding: 1.5rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="profile-container">
        <h1 class="profile-title">Tu Perfil</h1>

        <div class="profile-card">
            {{ form_start(form) }}
            <div class="form-group">
                {{ form_label(form.name, 'Nombre', {'label_attr': {'class': 'form-label'}}) }}
                <i class="fas fa-user input-icon"></i>
                {{ form_widget(form.name, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': 'Tu nombre'
                    }
                }) }}
            </div>

            <div class="form-group">
                {{ form_label(form.email, 'Correo Electrónico', {'label_attr': {'class': 'form-label'}}) }}
                <i class="fas fa-envelope input-icon"></i>
                {{ form_widget(form.email, {
                    'attr': {
                        'class': 'form-control',
                        'readonly': 'readonly'
                    }
                }) }}
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword, 'Nueva Contraseña (opcional)', {'label_attr': {'class': 'form-label'}}) }}
                <i class="fas fa-lock input-icon"></i>
                {{ form_widget(form.plainPassword, {
                    'attr': {
                        'class': 'form-control',
                        'placeholder': 'Deja en blanco para no cambiar'
                    }
                }) }}
            </div>

            <button type="submit" class="btn btn-profile">
                <i class="fas fa-save me-2"></i>
                Guardar cambios
            </button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
