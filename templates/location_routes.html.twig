{% extends 'base.html.twig' %}

{% block title %}Rutas en {{ location.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .explore-container {
            padding: 2rem 1rem;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 3rem;
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            position: relative;
        }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 4px;
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            border-radius: 2px;
        }

        .route-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            height: 100%;
            overflow: hidden;
        }

        .route-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
        }

        .route-card-header {
            background: linear-gradient(45deg, var(--gradient-start), var(--gradient-end));
            padding: 1.5rem;
            border-radius: 20px 20px 0 0;
            position: relative;
        }

        .route-name {
            color: white;
            font-size: 1.4rem;
            font-weight: 600;
            margin: 0;
            text-align: center;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }

        .route-content {
            padding: 1.5rem;
        }

        .route-detail {
            display: flex;
            align-items: center;
            margin-bottom: 1rem;
            padding: 0.8rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .route-detail:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .detail-icon {
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            color: #3498DB;
            font-size: 1.2rem;
        }

        .detail-content {
            flex: 1;
        }

        .detail-label {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 0.2rem;
        }

        .detail-value {
            font-size: 1rem;
            color: white;
            font-weight: 500;
        }

        .route-type-badge {
            background: linear-gradient(45deg, #2ECC71, #27AE60);
            color: white;
            padding: 0.4rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 500;
            display: inline-block;
        }

        .rating-stars {
            color: #F1C40F;
            font-size: 1.2rem;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            backdrop-filter: blur(10px);
        }

        .empty-state-icon {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.3);
            margin-bottom: 1rem;
        }

        .empty-state-text {
            color: rgba(255, 255, 255, 0.7);
            font-size: 1.2rem;
            font-weight: 500;
        }

        @media (max-width: 768px) {
            .explore-container {
                padding: 1rem;
            }

            .page-title {
                font-size: 2rem;
            }

            .route-card {
                margin-bottom: 1.5rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="explore-container">
        <h1 class="page-title">Rutas en {{ location.name }}</h1>
        <p class="text-center text-light">Ubicación GPS: {{ location.latitude }}, {{ location.longitude }}</p>

        {% if routes %}
            <div class="row g-4">
                {% for route in routes %}
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="route-card">
                            <div class="route-card-header">
                                <h2 class="route-name">{{ route.name }}</h2>
                            </div>
                            <div class="route-content">
                                <div class="route-detail">
                                    <div class="detail-icon">
                                        <i class="fas fa-map-marker-alt"></i>
                                    </div>
                                    <div class="detail-content">
                                        <div class="detail-label">Ubicación</div>
                                        <div class="detail-value">{{ location.name }}</div>
                                    </div>
                                </div>

                                <div class="route-detail">
                                    <div class="detail-icon">
                                        <i class="fas fa-mountain"></i>
                                    </div>
                                    <div class="detail-content">
                                        <div class="detail-label">Tipo de Ruta</div>
                                        <div class="detail-value">
                                            <span class="route-type-badge">{{ route.routeType.value }}</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="route-detail">
                                    <div class="detail-icon">
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <div class="detail-content">
                                        <div class="detail-label">Valoración</div>
                                        <div class="detail-value">
                                            <span class="rating-stars">
                                                {% for i in 1..5 %}
                                                    {% if i <= route.rating %}
                                                        <i class="fas fa-star"></i>
                                                    {% else %}
                                                        <i class="far fa-star"></i>
                                                    {% endif %}
                                                {% endfor %}
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="route-detail">
                                    <div class="detail-icon">
                                        <i class="fas fa-ruler-vertical"></i>
                                    </div>
                                    <div class="detail-content">
                                        <div class="detail-label">Longitud</div>
                                        <div class="detail-value">{{ route.length }} metros</div>
                                    </div>
                                </div>

                                <div class="route-detail">
                                    <div class="detail-icon">
                                        <i class="fas fa-layer-group"></i>
                                    </div>
                                    <div class="detail-content">
                                        <div class="detail-label">Número de largos</div>
                                        <div class="detail-value">{{ route.pitches }}</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                <i class="fas fa-route empty-state-icon"></i>
                <p class="empty-state-text">No hay rutas disponibles en esta ubicación.</p>
            </div>
        {% endif %}
    </div>
{% endblock %}
