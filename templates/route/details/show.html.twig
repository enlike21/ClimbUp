{% extends 'base.html.twig' %}

{% block title %}{{ route.name }} - Detalle de Ruta{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .route-detail-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
        }

        .route-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .route-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 2px 4px 4px rgba(0,0,0,0.1);
        }

        .route-type-badge {
            background: linear-gradient(45deg, var(--gradient-start), var(--gradient-end));
            color: white;
            padding: 0.5rem 1.5rem;
            border-radius: 25px;
            font-size: 1rem;
            font-weight: 500;
            display: inline-block;
            margin-top: 1rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .detail-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }

        .detail-item {
            display: flex;
            align-items: center;
            margin-bottom: 1.5rem;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            transition: all 0.3s ease;
        }

        .detail-item:hover {
            transform: translateY(-2px);
            background: rgba(255, 255, 255, 0.1);
        }

        .detail-icon {
            font-size: 1.5rem;
            width: 40px;
            margin-right: 1rem;
            color: #3498DB;
        }

        .detail-content {
            flex: 1;
        }

        .detail-label {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 0.2rem;
        }

        .detail-value {
            font-size: 1.1rem;
            font-weight: 500;
            color: white;
        }

        .rating-stars {
            color: #F1C40F;
            font-size: 1.2rem;
        }

        .action-buttons {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            justify-content: center;
        }

        .btn-action {
            padding: 0.8rem 2rem;
            border-radius: 12px;
            font-weight: 500;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-back {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            backdrop-filter: blur(5px);
        }

        .btn-edit {
            background: linear-gradient(45deg, #F1C40F, #F39C12);
            color: white;
        }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .route-url {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #3498DB;
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .route-url:hover {
            background: rgba(52, 152, 219, 0.1);
            color: #3498DB;
        }

        @media (max-width: 768px) {
            .route-detail-container {
                padding: 1rem;
            }

            .route-title {
                font-size: 2rem;
            }

            .detail-item {
                flex-direction: column;
                text-align: center;
            }

            .detail-icon {
                margin-right: 0;
                margin-bottom: 0.5rem;
            }

            .action-buttons {
                flex-direction: column;
            }

            .btn-action {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="route-detail-container">
        <div class="route-header">
            <h1 class="route-title">{{ route.name }}</h1>
            <span class="route-type-badge">
                <i class="fas fa-mountain me-2"></i>
                {{ route.routeType.value }}
            </span>
        </div>

        <div class="detail-card">
            <div class="detail-item">
                <i class="fas fa-star-half-alt detail-icon"></i>
                <div class="detail-content">
                    <div class="detail-label">Valoración</div>
                    <div class="detail-value">
                        <span class="rating-stars">
                            {% for i in 1..5 %}
                                {% if i <= route.rating %}
                                    <i class="fas fa-star"></i>
                                {% else %}
                                    <i class="far fa-star"></i>
                                {% endif %}
                            {% endfor %}
                        </span>
                    </div>
                </div>
            </div>

            <div class="detail-item">
                <i class="fas fa-ruler-vertical detail-icon"></i>
                <div class="detail-content">
                    <div class="detail-label">Longitud</div>
                    <div class="detail-value">{{ route.length }} metros</div>
                </div>
            </div>

            <div class="detail-item">
                <i class="fas fa-layer-group detail-icon"></i>
                <div class="detail-content">
                    <div class="detail-label">Número de largos</div>
                    <div class="detail-value">{{ route.pitches }}</div>
                </div>
            </div>

            <div class="detail-item">
                <i class="fas fa-map-marker-alt detail-icon"></i>
                <div class="detail-content">
                    <div class="detail-label">Ubicación</div>
                    <div class="detail-value">{{ route.location.name }}</div>
                </div>
            </div>
        </div>

        <div class="action-buttons">
            <a href="{% if is_granted('ROLE_ADMIN') %}{{ path('app_route_index') }}{% else %}{{ path('app_route_user_view') }}{% endif %}"
               class="btn btn-action btn-back">
                <i class="fas fa-arrow-left"></i>
                Volver al listado
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_route_edit', {'id': route.id}) }}" class="btn btn-action btn-edit">
                    <i class="fas fa-edit"></i>
                    Editar ruta
                </a>
            {% endif %}
        </div>
    </div>
{% endblock %}
