{% extends 'base.html.twig' %}

{% block title %}Listado de Rutas{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="text-center mb-4 text-gradient">Listado de Rutas de Escalada</h1>

        <!-- Mensajes Flash -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        <!-- Botón Añadir (Solo Administradores) -->
        {% if is_granted('ROLE_ADMIN') %}
            <div class="text-end mb-3">
                <a href="{{ path('app_route_new') }}" class="btn btn-primary shadow-lg">+ Añadir Nueva Ruta</a>
            </div>
        {% endif %}

        <!-- Tabla de Listado con estilo profesional -->
        <div class="table-responsive">
            <table class="table table-hover shadow-lg rounded">
                <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Rating</th>
                    <th class="text-center">Acciones</th>
                </tr>
                </thead>
                <tbody>
                {% for route in routes %}
                    <tr class="align-middle">
                        <td class="fw-bold">{{ route.name }}</td>
                        <td><span class="badge bg-gradient text-light">{{ route.routeType }}</span></td>
                        <td>{{ route.rating }}</td>
                        <td class="text-center d-flex justify-content-center gap-2">
                            <a href="{{ path('app_route_show', {'id': route.id}) }}" class="btn btn-sm btn-outline-info shadow-sm">👁 Ver</a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_route_edit', {'id': route.id}) }}" class="btn btn-sm btn-outline-warning shadow-sm">✏️ Editar</a>
                                <form action="{{ path('app_route_delete', {'id': route.id}) }}" method="post" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ route.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" onclick="return confirm('¿Estás seguro?')">🗑 Eliminar</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-muted">No hay rutas registradas.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Enlace de Registro -->
        <div class="text-center mt-4">
            <a href="{{ path('app_register') }}" class="btn btn-lg btn-outline-primary shadow">Crear una cuenta</a>
        </div>
    </div>

    <style>
        .text-gradient {
            background: linear-gradient(to right, #ff7e5f, #feb47b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: bold;
        }
        .btn-outline-info, .btn-outline-warning, .btn-outline-danger {
            transition: all 0.3s ease-in-out;
        }
        .btn-outline-info:hover { background-color: #17a2b8; color: white; }
        .btn-outline-warning:hover { background-color: #ffc107; color: black; }
        .btn-outline-danger:hover { background-color: #dc3545; color: white; }
        .bg-gradient {
            background: linear-gradient(to right, #007bff, #6610f2);
        }
    </style>
{% endblock %}
