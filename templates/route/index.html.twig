{% extends 'base.html.twig' %}

{% block title %}Listado de Rutas{% endblock %}

{% block body %}
    <h1 class="text-center mb-4 text-primary fw-bold">Listado de Rutas de Escalada</h1>

    <!-- Mensajes Flash -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <!-- Filtro de Tipos -->
    <div class="card shadow-sm p-3 mb-4">
        <form method="get" class="d-flex align-items-center">
            <label for="filter" class="me-2 fw-bold">Filtrar por tipo:</label>
            <select name="filter" id="filter" class="form-select me-2 w-auto">
                <option value="">Todos los tipos</option>
                <option value="Boulder" {% if filter == 'Boulder' %}selected{% endif %}>Boulder</option>
                <option value="Sport" {% if filter == 'Sport' %}selected{% endif %}>Sport</option>
                <option value="Trad" {% if filter == 'Trad' %}selected{% endif %}>Trad</option>
            </select>
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </form>
    </div>

    <!-- Botón Añadir -->
    <div class="text-end mb-3">
        <a href="{{ path('app_route_new') }}" class="btn btn-success">+ Añadir Nueva Ruta</a>
    </div>

    <!-- Tabla de Listado -->
    <div class="table-responsive">
        <table class="table table-striped table-hover rounded shadow-sm">
            <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Rating</th>
                <th class="text-center">Acciones</th>
            </tr>
            </thead>
            <tbody>
            {% for route in routes %}
                <tr>
                    <td class="fw-bold">{{ route.name }}</td>
                    <td><span class="badge bg-secondary">{{ route.routeType.value }}</span></td>
                    <td>{{ route.rating }}</td>
                    <td class="text-center">
                        <a href="{{ path('app_route_show', {'id': route.id}) }}" class="btn btn-sm btn-info">👁 Ver</a>
                        <a href="{{ path('app_route_edit', {'id': route.id}) }}" class="btn btn-sm btn-warning">✏️ Editar</a>
                        <form action="{{ path('app_route_delete', {'id': route.id}) }}" method="post" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ route.id) }}">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Estás seguro?')">🗑 Eliminar</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted">No hay rutas registradas.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    <nav aria-label="Paginación" class="d-flex justify-content-center mt-4">
        <ul class="pagination">
            <li class="page-item {% if current_page == 1 %}disabled{% endif %}">
                <a class="page-link" href="?page={{ current_page - 1 }}&filter={{ filter|default('') }}" aria-label="Anterior">&laquo;</a>
            </li>
            {% for page in 1..total_pages %}
                <li class="page-item {% if page == current_page %}active{% endif %}">
                    <a class="page-link" href="?page={{ page }}&filter={{ filter|default('') }}">{{ page }}</a>
                </li>
            {% endfor %}
            <li class="page-item {% if current_page == total_pages %}disabled{% endif %}">
                <a class="page-link" href="?page={{ current_page + 1 }}&filter={{ filter|default('') }}" aria-label="Siguiente">&raquo;</a>
            </li>
        </ul>
    </nav>
{% endblock %}
