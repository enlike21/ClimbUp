{% extends 'base.html.twig' %}

{% block title %}Explorar Rutas{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="text-center mb-4 text-primary fw-bold">Explorar Rutas Disponibles</h1>

        <div class="row">
            {% for route in routes %}
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-center text-dark fw-bold">{{ route.name }}</h5>
                            <p class="card-text"><strong>Tipo:</strong> {{ route.routeType.value }}</p>
                            <p class="card-text"><strong>Rating:</strong> {{ route.rating }}</p>
                            <p class="card-text"><strong>Longitud:</strong> {{ route.length }} metros</p>
                            <p class="card-text"><strong>Número de largos:</strong> {{ route.pitches }}</p>
                            <p class="card-text"><strong>Ubicación:</strong> {{ route.location.name }}</p>
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="text-center text-muted">No hay rutas disponibles.</p>
            {% endfor %}
        </div>
    </div>

    <style>
        .card {
            border-radius: 10px;
        }
        .card-title {
            font-size: 1.2rem;
        }
        .btn-primary {
            background-color: #007bff;
            border: none;
        }
        .btn-primary:hover {
            background-color: #0056b3;
        }
    </style>
{% endblock %}
