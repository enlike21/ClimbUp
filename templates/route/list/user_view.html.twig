{% extends 'base.html.twig' %}

{% block title %}Explorar Rutas{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .success-message {
            display: none;
            background: #2ECC71;
            color: white;
            padding: 1rem;
            text-align: center;
            border-radius: 10px;
            margin-top: 1rem;
        }
        .btn-save {
            position: relative;
            display: inline-block;
            background: linear-gradient(45deg, #2980B9, #3498DB);
            color: white;
            font-weight: bold;
            padding: 0.8rem 1.2rem;
            border: none;
            border-radius: 12px;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s ease-in-out;
        }

        .btn-save::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.3);
            transform: skewX(-20deg);
            transition: all 0.5s ease-in-out;
        }

        .btn-save:hover::before {
            left: 100%;
        }

        .btn-save:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 15px rgba(52, 152, 219, 0.5);
        }

        .btn-save:disabled {
            background: linear-gradient(45deg, #95A5A6, #7F8C8D);
            cursor: not-allowed;
            box-shadow: none;
            transform: none;
        }

        .filter-container {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .filter-container form {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
            justify-content: center;
        }

        .filter-container input,
        .filter-container select {
            height: 50px;
            border-radius: 12px;
            border: 2px solid rgba(255, 255, 255, 0.2);
            padding: 10px 15px;
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .filter-container input::placeholder {
            color: rgba(255, 255, 255, 0.6);
        }

        .filter-container button {
            height: 50px;
            border-radius: 12px;
            border: none;
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            color: white;
            font-weight: bold;
            padding: 0 20px;
            transition: all 0.3s ease;
        }

        .filter-container button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(52, 152, 219, 0.4);
        }

        .pagination .page-item.active .page-link {
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            border: none;
        }

        .pagination .page-item .page-link {
            color: #3498DB;
            font-weight: bold;
            border-radius: 12px;
            transition: all 0.3s ease;
        }

        .pagination .page-item .page-link:hover {
            background: rgba(52, 152, 219, 0.1);
            transform: translateY(-2px);
        }

        .explore-container {
            padding: 2rem 1rem;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 3rem;
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            position: relative;
        }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 4px;
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            border-radius: 2px;
        }

        .route-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            height: 100%;
            overflow: hidden;
        }

        .route-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
        }

        .route-card-header {
            background: linear-gradient(45deg, var(--gradient-start), var(--gradient-end));
            padding: 1.5rem;
            border-radius: 20px 20px 0 0;
            position: relative;
        }

        .route-name {
            color: white;
            font-size: 1.4rem;
            font-weight: 600;
            margin: 0;
            text-align: center;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
        }

        .route-content {
            padding: 1.5rem;
        }

        .route-detail {
            display: flex;
            align-items: center;
            margin-bottom: 1rem;
            padding: 0.8rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .route-detail:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .detail-icon {
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            color: #3498DB;
            font-size: 1.2rem;
        }

        .detail-content {
            flex: 1;
        }

        .detail-label {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 0.2rem;
        }

        .detail-value {
            font-size: 1rem;
            color: white;
            font-weight: 500;
        }

        .route-type-badge {
            background: linear-gradient(45deg, #2ECC71, #27AE60);
            color: white;
            padding: 0.4rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 500;
            display: inline-block;
        }

        .rating-stars {
            color: #F1C40F;
            font-size: 1.2rem;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            backdrop-filter: blur(10px);
        }

        .empty-state-icon {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.3);
            margin-bottom: 1rem;
        }

        .empty-state-text {
            color: rgba(255, 255, 255, 0.7);
            font-size: 1.2rem;
            font-weight: 500;
        }

        @media (max-width: 768px) {
            .explore-container {
                padding: 1rem;
            }

            .page-title {
                font-size: 2rem;
            }

            .route-card {
                margin-bottom: 1.5rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="explore-container">
        <h1 class="page-title">Explorar Rutas de Escalada</h1>

        <!-- Filtro de búsqueda -->
        <div class="filter-container">
            <form method="get">
                <input type="text" name="name" class="form-control" placeholder="Buscar por nombre..." value="{{ app.request.query.get('name', '') }}">
                <select name="route_type" class="form-select">
                    <option value="">Todos los tipos</option>
                    <option value="Sport" {% if app.request.query.get('route_type') == 'Sport' %}selected{% endif %}>Sport</option>
                    <option value="Trad" {% if app.request.query.get('route_type') == 'Trad' %}selected{% endif %}>Trad</option>
                    <option value="Boulder" {% if app.request.query.get('route_type') == 'Boulder' %}selected{% endif %}>Boulder</option>
                </select>
                <input type="text" name="rating" class="form-control" placeholder="Dificultad..." value="{{ app.request.query.get('rating', '') }}">
                <button type="submit" class="btn btn-primary">Filtrar</button>
            </form>
        </div>

        <!-- Filtrar rutas -->
        {% set filtered_routes = routes|filter(route =>
            (not app.request.query.get('name') or route.name matches '/.*' ~ app.request.query.get('name') ~ '.*/i') and
            (not app.request.query.get('route_type') or route.routeType.value == app.request.query.get('route_type')) and
            (not app.request.query.get('rating') or route.rating matches '/.*' ~ app.request.query.get('rating') ~ '.*/i')
            ) %}

        <!-- Paginación -->
        {% set page = app.request.query.get('page', 1) %}
        {% set per_page = 50 %}
        {% set total_routes = filtered_routes|length %}
        {% set total_pages = (total_routes / per_page)|round(0, 'ceil') %}
        {% set paginated_routes = filtered_routes|slice((page - 1) * per_page, per_page) %}

        {% if paginated_routes|length > 0 %}
            <div class="row g-4">
                {% for route in paginated_routes %}
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="route-card">
                            <div class="route-card-header">
                                <h2 class="route-name">{{ route.name }}</h2>
                            </div>
                            <div class="route-content">
                                <div class="route-detail">
                                    <div class="detail-icon">
                                        <i class="fas fa-mountain"></i>
                                    </div>
                                    <div class="detail-content">
                                        <div class="detail-label">Tipo de Ruta</div>
                                        <div class="detail-value">
                                            <span class="route-type-badge">{{ route.routeType.value }}</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="route-detail">
                                    <div class="detail-icon">
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <div class="detail-content">
                                        <div class="detail-label">Valoración</div>
                                        <div class="detail-value">
                            <span class="rating-stars">
                                {% for i in 1..5 %}
                                    {% if i <= route.rating %}
                                        <i class="fas fa-star"></i>
                                    {% else %}
                                        <i class="far fa-star"></i>
                                    {% endif %}
                                {% endfor %}
                            </span>
                                        </div>
                                    </div>
                                </div>

                                <div class="route-detail">
                                    <div class="detail-icon">
                                        <i class="fas fa-map-marker-alt"></i>
                                    </div>
                                    <div class="detail-content">
                                        <div class="detail-label">Ubicación</div>
                                        <div class="detail-value">{{ route.location.name }}</div>
                                    </div>
                                </div>

                                {% if app.user %}
                                        <button class="btn w-100 mt-2 save-route-btn btn-save" data-route-id="{{ route.id }}">
                                            <i class="fas fa-bookmark"></i> Guardar en Por Hacer
                                        </button>
                                {% endif %}
                                <div id="success-message" class="success-message">
                                    <i class="fas fa-check-circle"></i> ¡Ruta guardada en Por Hacer!
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <!-- Paginación -->
            <div class="d-flex justify-content-center mt-4">
                <nav>
                    <ul class="pagination">
                        {% if page > 1 %}
                            <li class="page-item">
                                <a class="page-link" href="{{ path(app.request.get('_route'), app.request.query.all|merge({'page': page - 1})) }}">Anterior</a>
                            </li>
                        {% endif %}
                        {% for p in 1..total_pages %}
                            <li class="page-item {% if p == page %}active{% endif %}">
                                <a class="page-link" href="{{ path(app.request.get('_route'), app.request.query.all|merge({'page': p})) }}">{{ p }}</a>
                            </li>
                        {% endfor %}
                        {% if page < total_pages %}
                            <li class="page-item">
                                <a class="page-link" href="{{ path(app.request.get('_route'), app.request.query.all|merge({'page': page + 1})) }}">Siguiente</a>
                            </li>
                        {% endif %}
                    </ul>
                </nav>
            </div>

        {% else %}
            <div class="empty-state">
                <i class="fas fa-route empty-state-icon"></i>
                <p class="empty-state-text">No hay rutas disponibles en este momento.</p>
            </div>
        {% endif %}

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                document.querySelectorAll(".save-route-btn").forEach(button => {
                    let routeId = button.dataset.routeId;

                    // Verificar si la ruta ya está guardada
                    fetch("{{ path('app_check_saved_route') }}", {
                        method: "POST",
                        body: JSON.stringify({ id: routeId }),
                        headers: {
                            "Content-Type": "application/json",
                            "X-Requested-With": "XMLHttpRequest"
                        }
                    })
                        .then(response => response.json())
                        .then(data => {
                            if (data.saved) {
                                button.classList.add("saved");
                                button.innerHTML = '<i class="fas fa-check"></i> Guardada';
                                button.disabled = true;
                            }
                        });

                    // Manejar el clic para guardar la ruta
                    button.addEventListener("click", function () {
                        fetch("{{ path('app_save_route') }}", {
                            method: "POST",
                            body: JSON.stringify({ id: routeId }),
                            headers: {
                                "Content-Type": "application/json",
                                "X-Requested-With": "XMLHttpRequest"
                            }
                        })
                            .then(response => response.json())
                            .then(data => {
                                if (data.success) {
                                    let messageBox = document.createElement("div");
                                    messageBox.className = "success-message";
                                    messageBox.innerHTML = '<i class="fas fa-check-circle"></i> ¡Ruta guardada en Por Hacer!';
                                    button.parentElement.appendChild(messageBox);
                                    messageBox.style.display = "block";

                                    setTimeout(() => {
                                        messageBox.style.display = "none";
                                        messageBox.remove();
                                    }, 3000);

                                    button.classList.add("saved");
                                    button.innerHTML = '<i class="fas fa-check"></i> Guardada';
                                    button.disabled = true;
                                }
                            })
                            .catch(error => console.error("Error:", error));
                    });
                });
            });
        </script>
    </div>
{% endblock %}
