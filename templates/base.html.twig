<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EscaladaApp{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500&family=Roboto:wght@400&display=swap" rel="stylesheet">

    <style>
        /* Elimina márgenes y paddings globalmente */
        html, body {
            height: 100%;  /* Asegura que el body y html ocupen toda la altura */
            margin: 0;  /* Elimina cualquier margen por defecto */
            padding: 0;  /* Elimina cualquier padding por defecto */
            width: 100%;  /* Asegura que el ancho sea el 100% */
            font-family: 'Roboto', sans-serif;  /* Fuente por defecto */
            background: #F0F8FF;  /* Fondo suave */
            background-image: linear-gradient(45deg, #7a9f3f, #2C4A35);  /* Fondo gradiente */
        }

        /* Barra de navegación */
        nav {
            background-color: #343a40;  /* Fondo oscuro */
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);  /* Sombra suave para dar profundidad */
        }

        nav .navbar-brand {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.75rem;
            font-weight: 600;
            color: #fff !important;  /* Color blanco para el texto */
            letter-spacing: 1px;
        }

        nav .navbar-nav .nav-link {
            color: #ccc !important;  /* Color claro para los enlaces */
            font-size: 1.1rem;
            padding: 10px 15px;
            text-transform: uppercase;  /* Transforma a mayúsculas para un look más moderno */
        }

        nav .navbar-nav .nav-link:hover {
            color: #f8f9fa !important;  /* Cambia el color al pasar el ratón */
            background-color: #007bff;  /* Fondo azul al hacer hover */
            border-radius: 5px;  /* Bordes redondeados en los enlaces */
        }

        /* Barra de navegación colapsada (para móviles) */
        .navbar-toggler {
            border-color: #007bff;  /* Cambia el color del borde del botón de colapsado */
        }

        .navbar-toggler-icon {
            background-color: #007bff;  /* Cambia el color del icono del botón */
        }

        /* Mejora el espaciado y disposición */
        .navbar-nav {
            margin-left: auto;  /* Alineación de los elementos de la derecha */
        }

        /* Contenedor principal */
        .container-fluid {
            height: 100%;  /* El contenedor ocupa toda la altura disponible */
            width: 100%;  /* El contenedor ocupa todo el ancho */
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        /* Título con fuente Montserrat */
        h1 {
            font-family: 'Montserrat', sans-serif;
            color: #ffffff;
        }

        /* Botones con tamaño y animación */
        .btn-lg {
            font-size: 1.5rem;
            padding: 20px 40px;
            border-radius: 50px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .btn-lg:hover {
            transform: scale(1.1);  /* Aumenta el tamaño al pasar el mouse */
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
        }

        /* Icono de escalada */
        .fas.fa-mountain {
            color: #ffffff;
        }
    </style>
</head>
<body>

<!-- Barra de navegación -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow">
    <div class="container">
        <a class="navbar-brand" href="{{ path('homepage') }}">EscaladaApp</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_route_index') }}">Rutas</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_route_new') }}">Añadir Ruta</a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_route_user_view') }}">Ver Rutas</a>
                    </li>
                {% endif %}

                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link text-danger" href="{{ path('logout') }}">Cerrar sesión</a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link text-light" href="{{ path('login') }}">Iniciar sesión</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-light" href="{{ path('app_register') }}">Registrarse</a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-5 pt-4">
    {% block body %}{% endblock %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
