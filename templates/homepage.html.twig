{% extends 'base.html.twig' %}

{% block title %}Bienvenido a la aplicación de Escalada{% endblock %}

{% block body %}
    <section class="hero-section d-flex align-items-center justify-content-center text-center" style="background-image: url('https://example.com/your-mountain-image.jpg'); background-size: cover; background-position: center; height: 100vh; color: white; border-radius: 20px;">
        <div class="container">
            <i class="fas fa-mountain fa-10x mb-4"></i>
            <h1 class="display-4 mb-4" style="font-family: 'Montserrat', sans-serif; font-weight: 700;">
                ¡Bienvenido a EscaladaApp!
                {% if app.user %} <br>{{ app.user.name }}{% endif %}
            </h1>

            <div class="d-flex justify-content-center">
                {% if app.user is not defined %}
                    <a href="{{ path('app_login_user') }}" class="btn btn-lg btn-outline-light m-3" style="border-radius: 50px; padding: 20px 40px; font-size: 1.5rem;">
                        Acceder como Usuario
                    </a>
                    <a href="{{ path('app_login_admin') }}" class="btn btn-lg btn-outline-warning m-3" style="border-radius: 50px; padding: 20px 40px; font-size: 1.5rem;">
                        Acceder como Administrador
                    </a>
                {% elseif is_granted('ROLE_USER') and not is_granted('ROLE_ADMIN') %}
                    {# Usuario normal, solo mostrar rutas #}
                    <a href="{{ path('app_route_user_view') }}" class="btn btn-lg btn-outline-light m-3" style="border-radius: 50px; padding: 20px 40px; font-size: 1.5rem;">
                        Mostrar Rutas
                    </a>
                {% elseif is_granted('ROLE_ADMIN') %}
                    {# Administrador, mostrar rutas y opción de administrar #}
                    <a href="{{ path('app_route_user_view') }}" class="btn btn-lg btn-outline-light m-3" style="border-radius: 50px; padding: 20px 40px; font-size: 1.5rem;">
                        Mostrar Rutas
                    </a>
                    <a href="{{ path('app_route_index') }}" class="btn btn-lg btn-outline-warning m-3" style="border-radius: 50px; padding: 20px 40px; font-size: 1.5rem;">
                        Administrar Rutas
                    </a>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
