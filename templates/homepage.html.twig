{% extends 'base.html.twig' %}

{% block title %}Bienvenido a la aplicación de Escalada{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .hero-section {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-align: center;
            padding: 2rem 1rem;
            overflow: hidden;
        }

        .hero-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: url('https://example.com/your-mountain-image.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            filter: brightness(0.7);
            z-index: -1;
        }

        .hero-content {
            position: relative;
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(10px);
            border-radius: 25px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            animation: fadeIn 1s ease-out;
        }

        .mountain-icon {
            font-size: 8rem;
            margin-bottom: 2rem;
            background: linear-gradient(45deg, #3498DB, #2ECC71);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.3));
            transition: transform 0.3s ease;
        }

        .mountain-icon:hover {
            transform: scale(1.05);
        }

        .welcome-title {
            font-family: 'Poppins', sans-serif;
            font-size: 3.5rem;
            font-weight: 700;
            margin-bottom: 2rem;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
            line-height: 1.2;
        }

        .user-name {
            font-size: 2rem;
            color: #3498DB;
            margin-top: 1rem;
            display: block;
        }

        .buttons-container {
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 2rem;
        }

        .btn-hero {
            padding: 1rem 2.5rem;
            font-size: 1.2rem;
            font-weight: 600;
            border-radius: 50px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
            overflow: hidden;
            border: 2px solid transparent;
            text-decoration: none;
        }

        .btn-hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                    120deg,
                    transparent,
                    rgba(255, 255, 255, 0.2),
                    transparent
            );
            transition: 0.5s;
        }

        .btn-hero:hover::before {
            left: 100%;
        }

        .btn-user {
            background: rgba(255, 255, 255, 0.1);
            border-color: white;
            color: white;
        }

        .btn-user:hover {
            background: white;
            color: #2C3E50;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

        .btn-admin {
            background: rgba(241, 196, 15, 0.1);
            border-color: #F1C40F;
            color: #F1C40F;
        }

        .btn-admin:hover {
            background: #F1C40F;
            color: #2C3E50;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive Design */
        @media (max-width: 1200px) {
            .hero-content {
                max-width: 90%;
            }

            .welcome-title {
                font-size: 3rem;
            }

            .mountain-icon {
                font-size: 7rem;
            }
        }

        @media (max-width: 992px) {
            .welcome-title {
                font-size: 2.5rem;
            }

            .mountain-icon {
                font-size: 6rem;
            }

            .btn-hero {
                padding: 0.9rem 2rem;
                font-size: 1.1rem;
            }
        }

        @media (max-width: 768px) {
            .hero-section {
                padding: 1rem;
            }

            .hero-content {
                padding: 1.5rem;
            }

            .welcome-title {
                font-size: 2rem;
            }

            .mountain-icon {
                font-size: 5rem;
                margin-bottom: 1.5rem;
            }

            .user-name {
                font-size: 1.5rem;
            }

            .buttons-container {
                flex-direction: column;
                gap: 0.8rem;
            }

            .btn-hero {
                width: 100%;
                padding: 0.8rem 1.5rem;
                font-size: 1rem;
            }
        }

        @media (max-width: 576px) {
            .hero-content {
                padding: 1rem;
            }

            .welcome-title {
                font-size: 1.8rem;
            }

            .mountain-icon {
                font-size: 4rem;
                margin-bottom: 1rem;
            }

            .user-name {
                font-size: 1.2rem;
            }
        }

        @media (max-height: 600px) {
            .hero-section {
                min-height: 120vh;
            }

            .mountain-icon {
                font-size: 3rem;
                margin-bottom: 0.5rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="hero-section">
        <div class="hero-content">
            <i class="fas fa-mountain mountain-icon"></i>
            <h1 class="welcome-title">
                ¡Bienvenido a EscaladaApp!
                {% if app.user %}
                    <span class="user-name">{{ app.user.name }}</span>
                {% endif %}
            </h1>

            <div class="buttons-container">
                {% if app.user is not defined %}
                    <a href="{{ path('app_login_user') }}" class="btn-hero btn-user">
                        Acceder como Usuario
                    </a>
                    <a href="{{ path('app_login_admin') }}" class="btn-hero btn-admin">
                        Acceder como Administrador
                    </a>
                {% elseif is_granted('ROLE_USER') and not is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_route_user_view') }}" class="btn-hero btn-user">
                        Mostrar Rutas
                    </a>
                {% elseif is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_route_user_view') }}" class="btn-hero btn-user">
                        Mostrar Rutas
                    </a>
                    <a href="{{ path('app_route_index') }}" class="btn-hero btn-admin">
                        Administrar Rutas
                    </a>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
